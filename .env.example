# Global
NODE_ENV=development
TZ=Europe/Moscow

# Web
WEB_HOST=0.0.0.0
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=Sanmarino CRM
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
WEB_HEALTHCHECK_PATH=/api/health
WEB_READINESS_PATH=/api/ready

# API
API_HOST=0.0.0.0
API_PORT=4000
API_PREFIX=api
API_LOG_LEVEL=info
API_CORS_ORIGIN=http://localhost:3000
API_HEALTHCHECK_PATH=/api/health
API_READINESS_PATH=/api/ready
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sanmarino_crm
REDIS_URL=redis://localhost:6379

# Worker
WORKER_CONCURRENCY=5
WORKER_OUTBOX_QUEUE=system.outbox
WORKER_KPI_QUEUE=analytics.kpi
WORKER_RESERVATION_QUEUE=inventory.reservation-expiry
WORKER_RECONCILIATION_QUEUE=reconciliation.daily
WORKER_HEALTHCHECK_MODE=cli

# Deploy / runtime placeholders
APP_DOMAIN=crm.example.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sanmarino_crm

# Secrets placeholders (TBD)
SESSION_COOKIE_SECRET=change-me
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me

# External providers (TBD)
SMTP_PROVIDER_TBD=
SMS_PROVIDER_TBD=
OBJECT_STORAGE_PROVIDER_TBD=
OBSERVABILITY_PROVIDER_TBD=
