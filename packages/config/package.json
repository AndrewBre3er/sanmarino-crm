{
  "name": "@sanmarino/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./eslint/base": "./eslint/base.cjs",
    "./prettier/base": "./prettier/base.cjs",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/node": "./tsconfig/node.json",
    "./tsconfig/next": "./tsconfig/next.json",
    "./vitest/base": "./vitest/base.ts"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "clean": "pnpm exec rimraf dist",
    "lint": "pnpm exec eslint --config eslint/base.cjs \"src/**/*.ts\"",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "format": "pnpm exec prettier --config prettier/base.cjs --check \"**/*.{ts,cjs,json}\"",
    "test": "pnpm exec vitest run --passWithNoTests",
    "test:unit": "pnpm exec vitest run --passWithNoTests",
    "test:integration": "pnpm exec vitest run --passWithNoTests",
    "test:e2e": "pnpm exec vitest run --passWithNoTests"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
