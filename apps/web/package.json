{
  "name": "@sanmarino/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "clean": "pnpm exec rimraf .next",
    "lint": "pnpm exec eslint --config ../../packages/config/eslint/base.cjs \"src/**/*.{ts,tsx}\"",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "format": "pnpm exec prettier --config ../../packages/config/prettier/base.cjs --check \"src/**/*.{ts,tsx,css}\"",
    "test": "pnpm exec vitest run",
    "test:unit": "pnpm exec vitest run tests",
    "test:integration": "pnpm exec vitest run --passWithNoTests",
    "test:e2e": "pnpm exec vitest run --passWithNoTests"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rimraf": "^6.0.1"
  }
}
