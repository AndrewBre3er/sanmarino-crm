{
  "name": "@sanmarino/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "clean": "pnpm exec rimraf dist",
    "lint": "pnpm exec eslint --config ../../packages/config/eslint/base.cjs \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "format": "pnpm exec prettier --config ../../packages/config/prettier/base.cjs --check \"src/**/*.ts\" \"tests/**/*.ts\" \"prisma/**/*.ts\"",
    "test": "pnpm exec vitest run",
    "test:unit": "pnpm exec vitest run tests/unit",
    "test:integration": "pnpm exec vitest run tests/integration",
    "test:e2e": "pnpm exec vitest run --passWithNoTests",
    "prisma:generate": "node ./scripts/prisma-generate.mjs",
    "prisma:validate": "node ./scripts/prisma-validate.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@sanmarino/types": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.1"
  }
}
