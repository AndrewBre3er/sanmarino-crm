generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["users", "crm", "orders", "inventory", "payments", "logistics", "finance", "analytics", "audit", "reconciliation", "system"]
}

/// Phase 8 scope:
/// - infra/system models + minimal core transactional foundation
/// - no full CRM/ERP schema implementation yet
/// TODO(implementation): add remaining business models only in their dedicated domain phases.

enum DealStatus {
  DRAFT       @map("draft")
  QUALIFIED   @map("qualified")
  PROPOSAL    @map("proposal")
  NEGOTIATION @map("negotiation")
  WON         @map("won")
  LOST        @map("lost")

  @@schema("crm")
}

enum OrderStatus {
  DRAFT          @map("draft")
  CONFIRMED      @map("confirmed")
  RESERVED       @map("reserved")
  IN_PROGRESS    @map("in_progress")
  COMPLETED      @map("completed")
  CLOSED         @map("closed")
  CANCELLED      @map("cancelled")
  PARTIAL_RETURN @map("partial_return")
  FULL_RETURN    @map("full_return")

  @@schema("orders")
}

enum OrderDeliveryStatus {
  NOT_SCHEDULED      @map("not_scheduled")
  SCHEDULED          @map("scheduled")
  PARTIALLY_DELIVERED @map("partially_delivered")
  DELIVERED          @map("delivered")
  FAILED             @map("failed")

  @@schema("orders")
}

enum OrderFulfillmentType {
  DELIVERY @map("delivery")
  PICKUP   @map("pickup")
  MANUAL   @map("manual")

  @@schema("orders")
}

enum DeliveryTaskStatus {
  PLANNED     @map("planned")
  ASSIGNED    @map("assigned")
  IN_TRANSIT  @map("in_transit")
  DELIVERED   @map("delivered")
  FAILED      @map("failed")
  RESCHEDULED @map("rescheduled")

  @@schema("logistics")
}

enum ReturnRequestStatus {
  DRAFT     @map("draft")
  SUBMITTED @map("submitted")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  PROCESSED @map("processed")
  CLOSED    @map("closed")

  @@schema("orders")
}

enum PaymentStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  REFUNDED  @map("refunded")

  @@schema("payments")
}

enum PaymentMethod {
  CASH          @map("cash")
  BANK_TRANSFER @map("bank_transfer")
  CARD          @map("card")
  SBP           @map("sbp")
  OTHER         @map("other")

  @@schema("payments")
}

model CrmLead {
  id                String    @id @default(uuid()) @db.Uuid
  source            String    @db.VarChar(128)
  status            String    @db.VarChar(64)
  title             String?   @db.VarChar(255)
  notes             String?   @db.Text
  responsibleUserId String?   @map("responsible_user_id") @db.VarChar(128) // TODO: users.user relation in auth/users phase.
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  version           Int       @default(1)
  deals             CrmDeal[]

  @@index([status])
  @@index([source])
  @@map("leads")
  @@schema("crm")
}

model CrmDeal {
  id                String       @id @default(uuid()) @db.Uuid
  leadId            String?      @map("lead_id") @db.Uuid
  lead              CrmLead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  status            DealStatus
  title             String       @db.VarChar(255)
  notes             String?      @db.Text
  responsibleUserId String?      @map("responsible_user_id") @db.VarChar(128) // TODO: users.user relation in auth/users phase.
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version           Int          @default(1)
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz(6)
  deletedBy         String?      @map("deleted_by") @db.VarChar(128)
  deleteReason      String?      @map("delete_reason") @db.Text
  isDeleted         Boolean      @default(false) @map("is_deleted")
  orders            OrdersOrder[]

  @@index([leadId])
  @@index([status])
  @@index([isDeleted])
  @@map("deals")
  @@schema("crm")
}

model OrdersOrder {
  id             String                @id @default(uuid()) @db.Uuid
  orderNumber    String                @unique @map("order_number") @db.VarChar(64)
  dealId         String                @map("deal_id") @db.Uuid
  deal           CrmDeal               @relation(fields: [dealId], references: [id], onDelete: Restrict)
  status         OrderStatus
  fulfillmentType OrderFulfillmentType @default(MANUAL) @map("fulfillment_type")
  deliveryStatus OrderDeliveryStatus   @default(NOT_SCHEDULED) @map("delivery_status")
  currency       String                @default("RUB") @db.VarChar(3)
  totalAmount    Decimal               @default(0) @map("total_amount") @db.Decimal(14, 2)
  confirmedAt    DateTime?             @map("confirmed_at") @db.Timestamptz(6)
  completedAt    DateTime?             @map("completed_at") @db.Timestamptz(6)
  closedAt       DateTime?             @map("closed_at") @db.Timestamptz(6)
  cancelledAt    DateTime?             @map("cancelled_at") @db.Timestamptz(6)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  version        Int                   @default(1)
  deletedAt      DateTime?             @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?               @map("deleted_by") @db.VarChar(128)
  deleteReason   String?               @map("delete_reason") @db.Text
  isDeleted      Boolean               @default(false) @map("is_deleted")
  items          OrdersOrderItem[]
  // TODO(phase9+): enforce delivery(1..N tasks)/pickup(0 tasks) invariant in transaction/domain layer.
  deliveryTasks  LogisticsDeliveryTask[]
  returnRequests OrdersReturnRequest[]
  payments       PaymentsPayment[]

  @@index([dealId])
  @@index([status])
  @@index([fulfillmentType])
  @@index([deliveryStatus])
  @@index([isDeleted])
  @@map("orders")
  @@schema("orders")
}

model OrdersOrderItem {
  id                  String      @id @default(uuid()) @db.Uuid
  orderId             String      @map("order_id") @db.Uuid
  order               OrdersOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  lineNo              Int         @map("line_no")
  productRef          String      @map("product_ref") @db.VarChar(128) // TODO: inventory.products relation in inventory phase.
  productNameSnapshot String      @map("product_name_snapshot") @db.VarChar(255)
  qty                 Decimal     @db.Decimal(14, 3)
  retailPrice         Decimal     @map("retail_price") @db.Decimal(14, 2)
  discountAmount      Decimal     @default(0) @map("discount_amount") @db.Decimal(14, 2)
  lineTotal           Decimal     @map("line_total") @db.Decimal(14, 2)
  costSnapshot        Decimal?    @map("cost_snapshot") @db.Decimal(14, 2)
  notes               String?     @db.Text
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  version             Int         @default(1)

  @@unique([orderId, lineNo])
  @@index([orderId])
  @@map("order_items")
  @@schema("orders")
}

model LogisticsDeliveryTask {
  id             String             @id @default(uuid()) @db.Uuid
  orderId        String             @map("order_id") @db.Uuid
  order          OrdersOrder        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status         DeliveryTaskStatus
  sequenceNo     Int?               @map("sequence_no")
  plannedDate    DateTime?          @map("planned_date") @db.Date
  deliveredAt    DateTime?          @map("delivered_at") @db.Timestamptz(6)
  failureReason  String?            @map("failure_reason") @db.Text
  addressText    String?            @map("address_text") @db.Text
  recipientName  String?            @map("recipient_name") @db.VarChar(255)
  recipientPhone String?            @map("recipient_phone") @db.VarChar(64)
  createdBy      String?            @map("created_by") @db.VarChar(128) // TODO: users.user relation in auth/users phase.
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  version        Int                @default(1)

  @@index([orderId])
  @@index([status])
  @@map("delivery_tasks")
  @@schema("logistics")
}

model OrdersReturnRequest {
  id                   String              @id @default(uuid()) @db.Uuid
  orderId              String              @map("order_id") @db.Uuid
  order                OrdersOrder         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status               ReturnRequestStatus
  reason               String              @db.Text
  requestedRefundAmount Decimal?           @map("requested_refund_amount") @db.Decimal(14, 2)
  approvedRefundAmount Decimal?            @map("approved_refund_amount") @db.Decimal(14, 2)
  submittedAt          DateTime?           @map("submitted_at") @db.Timestamptz(6)
  approvedAt           DateTime?           @map("approved_at") @db.Timestamptz(6)
  processedAt          DateTime?           @map("processed_at") @db.Timestamptz(6)
  closedAt             DateTime?           @map("closed_at") @db.Timestamptz(6)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  version              Int                 @default(1)
  deletedAt            DateTime?           @map("deleted_at") @db.Timestamptz(6)
  deletedBy            String?             @map("deleted_by") @db.VarChar(128)
  deleteReason         String?             @map("delete_reason") @db.Text
  isDeleted            Boolean             @default(false) @map("is_deleted")

  @@index([orderId])
  @@index([status])
  @@index([isDeleted])
  @@map("return_requests")
  @@schema("orders")
}

model PaymentsPayment {
  id                String        @id @default(uuid()) @db.Uuid
  paymentNumber     String        @unique @map("payment_number") @db.VarChar(64)
  orderId           String        @map("order_id") @db.Uuid
  order             OrdersOrder   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status            PaymentStatus
  paymentMethod     PaymentMethod @map("payment_method")
  amount            Decimal       @db.Decimal(14, 2)
  refundedAmount    Decimal       @default(0) @map("refunded_amount") @db.Decimal(14, 2)
  receivedAt        DateTime?     @map("received_at") @db.Timestamptz(6)
  externalReference String?       @map("external_reference") @db.VarChar(255)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  version           Int           @default(1)
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz(6)
  deletedBy         String?       @map("deleted_by") @db.VarChar(128)
  deleteReason      String?       @map("delete_reason") @db.Text
  isDeleted         Boolean       @default(false) @map("is_deleted")

  @@index([orderId])
  @@index([status])
  @@index([isDeleted])
  @@map("payments")
  @@schema("payments")
}

enum IdempotencyStatus {
  STARTED   @map("started")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@schema("system")
}

enum OutboxStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  PROCESSED  @map("processed")
  FAILED     @map("failed")
  DEAD_LETTER @map("dead_letter")

  @@schema("system")
}

model SystemIdempotencyRecord {
  id                 String            @id @default(uuid()) @db.Uuid
  idempotencyKey     String            @map("idempotency_key") @db.VarChar(128)
  scope              String            @db.VarChar(128)
  requestHash        String            @map("request_hash") @db.VarChar(128)
  status             IdempotencyStatus
  responseStatusCode Int?              @map("response_status_code")
  responseBody       Json?             @map("response_body")
  lockedUntil        DateTime?         @map("locked_until") @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  version            Int?
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz(6)
  deletedBy          String?           @map("deleted_by") @db.VarChar(128)
  deleteReason       String?           @map("delete_reason") @db.Text
  isDeleted          Boolean           @default(false) @map("is_deleted")

  @@unique([scope, idempotencyKey])
  @@index([status])
  @@index([lockedUntil])
  @@index([isDeleted])
  @@map("idempotency_records")
  @@schema("system")
}

model SystemOutboxRecord {
  id            String       @id @default(uuid()) @db.Uuid
  eventType     String       @map("event_type") @db.VarChar(128)
  aggregateType String       @map("aggregate_type") @db.VarChar(128)
  aggregateId   String       @map("aggregate_id") @db.VarChar(128)
  payload       Json
  status        OutboxStatus @default(PENDING)
  attemptCount  Int          @default(0) @map("attempt_count")
  nextAttemptAt DateTime?    @map("next_attempt_at") @db.Timestamptz(6)
  errorMessage  String?      @map("error_message") @db.Text
  processedAt   DateTime?    @map("processed_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version       Int?
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?      @map("deleted_by") @db.VarChar(128)
  deleteReason  String?      @map("delete_reason") @db.Text
  isDeleted     Boolean      @default(false) @map("is_deleted")

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([isDeleted])
  @@map("outbox_events")
  @@schema("system")
}

model AuditLogRecord {
  id            String    @id @default(uuid()) @db.Uuid
  eventId       String    @unique @map("event_id") @db.VarChar(128)
  occurredAt    DateTime  @map("occurred_at") @db.Timestamptz(6)
  action        String    @db.VarChar(128)
  entityType    String    @map("entity_type") @db.VarChar(128)
  entityId      String    @map("entity_id") @db.VarChar(128)
  actorUserId   String?   @map("actor_user_id") @db.VarChar(128)
  requestId     String?   @map("request_id") @db.VarChar(128)
  correlationId String?   @map("correlation_id") @db.VarChar(128)
  payload       Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  version       Int?
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?   @map("deleted_by") @db.VarChar(128)
  deleteReason  String?   @map("delete_reason") @db.Text
  isDeleted     Boolean   @default(false) @map("is_deleted")

  @@index([entityType, entityId])
  @@index([occurredAt])
  @@index([isDeleted])
  @@map("audit_log_records")
  @@schema("audit")
}
