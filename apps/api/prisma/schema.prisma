  warehouseId          String                @map("warehouse_id") @db.Uuid
  warehouse            InventoryWarehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  orderId              String?               @map("order_id") @db.Uuid
  order                OrdersOrder?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  dealId               String?               @map("deal_id") @db.Uuid
  deal                 CrmDeal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  qty                  Decimal               @db.Decimal(14, 3)
