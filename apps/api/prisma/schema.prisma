  @@index([productId])
  @@map("purchase_receipt_items")
  @@schema("inventory")
}

model PaymentsPayment {
  id                String                  @id @default(uuid()) @db.Uuid
  paymentNumber     String                  @unique @map("payment_number") @db.VarChar(64)
  orderId           String                  @map("order_id") @db.Uuid
  order             OrdersOrder             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status            PaymentStatus
  paymentMethod     PaymentMethod           @map("payment_method")
  amount            Decimal                 @db.Decimal(14, 2)
  refundedAmount    Decimal                 @default(0) @map("refunded_amount") @db.Decimal(14, 2)
  receivedAt        DateTime?               @map("received_at") @db.Timestamptz(6)
  externalReference String?                 @map("external_reference") @db.VarChar(255)
  createdBy         String                  @map("created_by") @db.Uuid
  createdByUser     UsersUser               @relation("PaymentsPaymentCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  version           Int                     @default(1)
  deletedAt         DateTime?               @map("deleted_at") @db.Timestamptz(6)
  deletedBy         String?                 @map("deleted_by") @db.Uuid
  deletedByUser     UsersUser?              @relation("PaymentsPaymentDeletedByUser", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason      String?                 @map("delete_reason") @db.Text
  isDeleted         Boolean                 @default(false) @map("is_deleted")
  cashOperations    PaymentsCashOperation[]
  financeEntries    FinanceFinanceEntry[]

  @@index([orderId])
  @@index([status])
  @@index([createdBy])
  @@index([isDeleted])
  @@map("payments")
  @@schema("payments")
}

model PaymentsCashOperation {
  id                String                @id @default(uuid()) @db.Uuid
  paymentId         String?               @map("payment_id") @db.Uuid
  payment           PaymentsPayment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  returnRequestId   String?               @map("return_request_id") @db.Uuid
  returnRequest     OrdersReturnRequest?  @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)
  operationType     CashOperationType     @map("operation_type")
  amount            Decimal               @db.Decimal(14, 2)
  currency          String                @default("RUB") @db.VarChar(3)
  performedAt       DateTime              @map("performed_at") @db.Timestamptz(6)
  externalReference String?               @map("external_reference") @db.VarChar(255)
  createdBy         String                @map("created_by") @db.Uuid
  createdByUser     UsersUser             @relation("PaymentsCashOperationCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  financeEntries    FinanceFinanceEntry[]

  @@index([paymentId])
  @@index([returnRequestId])
  @@index([performedAt])
  @@map("cash_operations")
  @@schema("payments")
}

model FinanceFinanceEntry {
  id                 String                   @id @default(uuid()) @db.Uuid
  entryType          FinanceEntryType         @map("entry_type")
  orderId            String?                  @map("order_id") @db.Uuid
  order              OrdersOrder?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  paymentId          String?                  @map("payment_id") @db.Uuid
  payment            PaymentsPayment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  expenseId          String?                  @map("expense_id") @db.Uuid
  expense            FinanceExpense?          @relation("FinanceEntryExpense", fields: [expenseId], references: [id], onDelete: SetNull)
  marketingExpenseId String?                  @map("marketing_expense_id") @db.Uuid
  marketingExpense   FinanceMarketingExpense? @relation("FinanceEntryMarketingExpense", fields: [marketingExpenseId], references: [id], onDelete: SetNull)
  cashOperationId    String?                  @map("cash_operation_id") @db.Uuid
  cashOperation      PaymentsCashOperation?   @relation(fields: [cashOperationId], references: [id], onDelete: SetNull)
  returnRequestId    String?                  @map("return_request_id") @db.Uuid
  returnRequest      OrdersReturnRequest?     @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)
  amount             Decimal                  @db.Decimal(14, 2)
  currency           String                   @default("RUB") @db.VarChar(3)
  recognizedAt       DateTime                 @map("recognized_at") @db.Timestamptz(6)
  description        String?                  @db.Text
  createdBy          String                   @map("created_by") @db.Uuid
  createdByUser      UsersUser                @relation("FinanceFinanceEntryCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([entryType])
  @@index([paymentId])
  @@index([expenseId])
  @@index([marketingExpenseId])
  @@index([recognizedAt])
  @@map("finance_entries")
  @@schema("finance")
}

model FinanceExpense {
  id             String                @id @default(uuid()) @db.Uuid
  expenseType    ExpenseType           @map("expense_type")
  amount         Decimal               @db.Decimal(14, 2)
  currency       String                @default("RUB") @db.VarChar(3)
  occurredAt     DateTime              @map("occurred_at") @db.Timestamptz(6)
  description    String?               @db.Text
  relatedOrderId String?               @map("related_order_id") @db.Uuid
  relatedOrder   OrdersOrder?          @relation("FinanceExpenseRelatedOrder", fields: [relatedOrderId], references: [id], onDelete: SetNull)
  financeEntries FinanceFinanceEntry[] @relation("FinanceEntryExpense")
  createdBy      String                @map("created_by") @db.Uuid
  createdByUser  UsersUser             @relation("FinanceExpenseCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([expenseType])
  @@index([occurredAt])
  @@map("expenses")
  @@schema("finance")
}

model FinanceMarketingExpense {
  id             String                @id @default(uuid()) @db.Uuid
  source         String                @db.VarChar(128)
  campaign       String?               @db.VarChar(255)
  amount         Decimal               @db.Decimal(14, 2)
  currency       String                @default("RUB") @db.VarChar(3)
  occurredAt     DateTime              @map("occurred_at") @db.Timestamptz(6)
  description    String?               @db.Text
  financeEntries FinanceFinanceEntry[] @relation("FinanceEntryMarketingExpense")
  createdBy      String                @map("created_by") @db.Uuid
  createdByUser  UsersUser             @relation("FinanceMarketingExpenseCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([source])
  @@index([occurredAt])
  @@map("marketing_expenses")
  @@schema("finance")
}

enum ReconciliationReportStatus {
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@schema("reconciliation")
}

model ReconciliationReport {
  id         String                   @id @default(uuid()) @db.Uuid
  reportDate DateTime                 @unique @map("report_date") @db.Date
  status     ReconciliationReportStatus
  summary    Json
  issuesCount Int                     @default(0) @map("issues_count")
  createdAt  DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, reportDate])
  @@map("reports")
  @@schema("reconciliation")
}

enum IdempotencyStatus {
  STARTED   @map("started")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@schema("system")
}

enum OutboxStatus {
  PENDING     @map("pending")
  PROCESSING  @map("processing")
  PROCESSED   @map("processed")
  FAILED      @map("failed")
  DEAD_LETTER @map("dead_letter")

  @@schema("system")
}

model SystemIdempotencyRecord {
  id                 String            @id @default(uuid()) @db.Uuid
  idempotencyKey     String            @map("idempotency_key") @db.VarChar(128)
  scope              String            @db.VarChar(128)
  requestHash        String            @map("request_hash") @db.VarChar(128)
  status             IdempotencyStatus
  responseStatusCode Int?              @map("response_status_code")
  responseBody       Json?             @map("response_body")
  lockedUntil        DateTime?         @map("locked_until") @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  version            Int?
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz(6)
  deletedBy          String?           @map("deleted_by") @db.Uuid
  deletedByUser      UsersUser?        @relation("SystemIdempotencyRecordDeletedByUser", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason       String?           @map("delete_reason") @db.Text
  isDeleted          Boolean           @default(false) @map("is_deleted")

  @@unique([scope, idempotencyKey])
  @@index([status])
  @@index([lockedUntil])
  @@index([isDeleted])
  @@map("idempotency_records")
  @@schema("system")
}

model SystemOutboxRecord {
  id            String       @id @default(uuid()) @db.Uuid
  eventType     String       @map("event_type") @db.VarChar(128)
  aggregateType String       @map("aggregate_type") @db.VarChar(128)
  aggregateId   String       @map("aggregate_id") @db.VarChar(128)
  payload       Json
  status        OutboxStatus @default(PENDING)
  attemptCount  Int          @default(0) @map("attempt_count")
  nextAttemptAt DateTime?    @map("next_attempt_at") @db.Timestamptz(6)
  errorMessage  String?      @map("error_message") @db.Text
  processedAt   DateTime?    @map("processed_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version       Int?
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?      @map("deleted_by") @db.Uuid
  deletedByUser UsersUser?   @relation("SystemOutboxRecordDeletedByUser", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason  String?      @map("delete_reason") @db.Text
  isDeleted     Boolean      @default(false) @map("is_deleted")

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([isDeleted])
  @@map("outbox_events")
  @@schema("system")
}

model AuditLogRecord {
  id            String     @id @default(uuid()) @db.Uuid
  eventId       String     @unique @map("event_id") @db.VarChar(128)
  occurredAt    DateTime   @map("occurred_at") @db.Timestamptz(6)
  action        String     @db.VarChar(128)
  entityType    String     @map("entity_type") @db.VarChar(128)
  entityId      String     @map("entity_id") @db.VarChar(128)
  actorUserId   String?    @map("actor_user_id") @db.Uuid
  actorUser     UsersUser? @relation("AuditLogRecordActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  requestId     String?    @map("request_id") @db.VarChar(128)
  correlationId String?    @map("correlation_id") @db.VarChar(128)
  payload       Json?
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  version       Int?
  deletedAt     DateTime?  @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?    @map("deleted_by") @db.Uuid
  deletedByUser UsersUser? @relation("AuditLogRecordDeletedByUser", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason  String?    @map("delete_reason") @db.Text
  isDeleted     Boolean    @default(false) @map("is_deleted")

  @@index([entityType, entityId])
  @@index([occurredAt])
  @@index([isDeleted])
  @@map("audit_log_records")
  @@schema("audit")
}
