generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["users", "crm", "orders", "inventory", "payments", "logistics", "finance", "analytics", "audit", "reconciliation", "system"]
}

/// Phase 6 scope:
/// - infra/system schema only
/// - no business/domain models
/// TODO(implementation): add business models only when domain implementation phase starts.

enum IdempotencyStatus {
  STARTED   @map("started")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@schema("system")
}

enum OutboxStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  PROCESSED  @map("processed")
  FAILED     @map("failed")
  DEAD_LETTER @map("dead_letter")

  @@schema("system")
}

model SystemIdempotencyRecord {
  id                 String            @id @default(uuid()) @db.Uuid
  idempotencyKey     String            @map("idempotency_key") @db.VarChar(128)
  scope              String            @db.VarChar(128)
  requestHash        String            @map("request_hash") @db.VarChar(128)
  status             IdempotencyStatus
  responseStatusCode Int?              @map("response_status_code")
  responseBody       Json?             @map("response_body")
  lockedUntil        DateTime?         @map("locked_until") @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  version            Int?
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz(6)
  deletedBy          String?           @map("deleted_by") @db.VarChar(128)
  deleteReason       String?           @map("delete_reason") @db.Text
  isDeleted          Boolean           @default(false) @map("is_deleted")

  @@unique([scope, idempotencyKey])
  @@index([status])
  @@index([lockedUntil])
  @@index([isDeleted])
  @@map("idempotency_records")
  @@schema("system")
}

model SystemOutboxRecord {
  id            String       @id @default(uuid()) @db.Uuid
  eventType     String       @map("event_type") @db.VarChar(128)
  aggregateType String       @map("aggregate_type") @db.VarChar(128)
  aggregateId   String       @map("aggregate_id") @db.VarChar(128)
  payload       Json
  status        OutboxStatus @default(PENDING)
  attemptCount  Int          @default(0) @map("attempt_count")
  nextAttemptAt DateTime?    @map("next_attempt_at") @db.Timestamptz(6)
  errorMessage  String?      @map("error_message") @db.Text
  processedAt   DateTime?    @map("processed_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version       Int?
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?      @map("deleted_by") @db.VarChar(128)
  deleteReason  String?      @map("delete_reason") @db.Text
  isDeleted     Boolean      @default(false) @map("is_deleted")

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([isDeleted])
  @@map("outbox_events")
  @@schema("system")
}

model AuditLogRecord {
  id            String    @id @default(uuid()) @db.Uuid
  eventId       String    @unique @map("event_id") @db.VarChar(128)
  occurredAt    DateTime  @map("occurred_at") @db.Timestamptz(6)
  action        String    @db.VarChar(128)
  entityType    String    @map("entity_type") @db.VarChar(128)
  entityId      String    @map("entity_id") @db.VarChar(128)
  actorUserId   String?   @map("actor_user_id") @db.VarChar(128)
  requestId     String?   @map("request_id") @db.VarChar(128)
  correlationId String?   @map("correlation_id") @db.VarChar(128)
  payload       Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  version       Int?
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?   @map("deleted_by") @db.VarChar(128)
  deleteReason  String?   @map("delete_reason") @db.Text
  isDeleted     Boolean   @default(false) @map("is_deleted")

  @@index([entityType, entityId])
  @@index([occurredAt])
  @@index([isDeleted])
  @@map("audit_log_records")
  @@schema("audit")
}
