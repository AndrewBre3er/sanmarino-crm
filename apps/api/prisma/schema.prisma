  expiresAt            DateTime              @map("expires_at") @db.Timestamptz(6)
  releasedAt           DateTime?             @map("released_at") @db.Timestamptz(6)
  promotedReservationId String?              @map("promoted_reservation_id") @db.Uuid
  promotedReservation  InventoryReservation? @relation(fields: [promotedReservationId], references: [id], onDelete: SetNull)
  createdBy            String                @map("created_by") @db.Uuid
  createdByUser        UsersUser             @relation("InventoryStockLockCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([productId, warehouseId, status])
  @@index([orderId])
  @@index([dealId])
  @@index([expiresAt])
  @@map("stock_locks")
  @@schema("inventory")
}

model InventoryReservation {
