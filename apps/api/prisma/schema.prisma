generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["users", "crm", "orders", "inventory", "payments", "logistics", "finance", "analytics", "audit", "reconciliation", "system"]
}

/// Phase 15 scope:
/// - infra/system models + users + CRM core + supply/inventory + payments/finance + logistics/fulfillment contract foundation
/// - transactional domain workflows remain deferred until dedicated implementation slices
/// TODO(implementation): add remaining business models only in their dedicated domain phases.
/// TODO(phase14+): wire payment completion/refund flows to finance entries via transactional use-cases and outbox events.
/// TODO(phase14+): keep finance income writes internal-only and triggered from payment completion flow.
/// TODO(phase15+): implement logistics command handlers, workflow orchestration, and worker consumers in dedicated slices.

enum LeadStatus {
  NEW           @map("new")
  IN_PROCESSING @map("in_processing")
  CANCELLED     @map("cancelled")

  @@schema("crm")
}

enum DealStatus {
  IN_PROGRESS        @map("in_progress")
  CONVERTED_TO_ORDER @map("converted_to_order")
  CANCELLED          @map("cancelled")

  @@schema("crm")
}

enum OrderStatus {
  ASSEMBLING                 @map("assembling")
  READY_FOR_PARTIAL_SHIPMENT @map("ready_for_partial_shipment")
  READY_FOR_SHIPMENT         @map("ready_for_shipment")
  PARTIALLY_SHIPPED          @map("partially_shipped")
  SHIPPED                    @map("shipped")

  @@schema("orders")
}

enum OrderPaymentControlStatus {
  NONE       @map("none")
  ON_CONTROL @map("on_control")
  PROBLEM    @map("problem")

  @@schema("orders")
}

enum OrderDeliveryStatus {
  NOT_SCHEDULED       @map("not_scheduled")
  SCHEDULED           @map("scheduled")
  PARTIALLY_DELIVERED @map("partially_delivered")
  DELIVERED           @map("delivered")
  FAILED              @map("failed")

  @@schema("orders")
}

enum OrderFulfillmentType {
  DELIVERY @map("delivery")
  PICKUP   @map("pickup")
  MANUAL   @map("manual")

  @@schema("orders")
}

enum FulfillmentStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  FAILED    @map("failed")
  CANCELLED @map("cancelled")

  @@schema("orders")
}

enum DeliveryTaskStatus {
  PLANNED     @map("planned")
  ASSIGNED    @map("assigned")
  IN_TRANSIT  @map("in_transit")
  DELIVERED   @map("delivered")
  FAILED      @map("failed")
  RESCHEDULED @map("rescheduled")

  @@schema("logistics")
}

enum SlotStatus {
  OPEN   @map("open")
  HELD   @map("held")
  BOOKED @map("booked")
  CLOSED @map("closed")

  @@schema("logistics")
}

enum RouteDayStatus {
  PLANNED   @map("planned")
  ACTIVE    @map("active")
  CLOSED    @map("closed")
  CANCELLED @map("cancelled")

  @@schema("logistics")
}

enum ReturnRequestStatus {
  CREATED   @map("created")
  CONFIRMED @map("confirmed")
  PROCESSED @map("processed")
  CLOSED    @map("closed")

  @@schema("orders")
}

enum SupplierRequestStatus {
  FORMED                @map("formed")
  CONFIRMED_BY_SUPPLIER @map("confirmed_by_supplier")
  PAID                  @map("paid")
  STOCKED               @map("stocked")

  @@schema("inventory")
}

enum ProductUnit {
  PIECE        @map("шт")
  SQUARE_METER @map("кв.м")
  LINEAR_METER @map("п.м")
  SERVICE      @map("услуга")

  @@schema("inventory")
}

enum StockLockStatus {
  ACTIVE   @map("active")
  EXPIRED  @map("expired")
  RELEASED @map("released")
  PROMOTED @map("promoted")

  @@schema("inventory")
}

enum ReservationStatus {
  ACTIVE    @map("active")
  RELEASED  @map("released")
  EXPIRED   @map("expired")
  CONSUMED  @map("consumed")
  CANCELLED @map("cancelled")

  @@schema("inventory")
}

enum InventoryMovementType {
  RECEIPT                 @map("receipt")
  ISSUE                   @map("issue")
  RETURN_TO_STOCK         @map("return_to_stock")
  WRITEOFF                @map("writeoff")
  ADJUSTMENT              @map("adjustment")
  RESERVATION_CREATE      @map("reservation_create")
  RESERVATION_RELEASE     @map("reservation_release")
  TRANSFER_TO_QUARANTINE  @map("transfer_to_quarantine")
  RELEASE_FROM_QUARANTINE @map("release_from_quarantine")

  @@schema("inventory")
}

enum InventoryBucket {
  ON_HAND    @map("on_hand")
  RESERVED   @map("reserved")
  AVAILABLE  @map("available")
  QUARANTINE @map("quarantine")

  @@schema("inventory")
}

enum PaymentStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  REFUNDED  @map("refunded")

  @@schema("payments")
}

enum PaymentMethod {
  CASH          @map("cash")
  BANK_TRANSFER @map("bank_transfer")
  CARD          @map("card")
  SBP           @map("sbp")
  OTHER         @map("other")

  @@schema("payments")
}

enum CashOperationType {
  CASH_IN  @map("cash_in")
  CASH_OUT @map("cash_out")
  REFUND   @map("refund")

  @@schema("payments")
}

enum FinanceEntryType {
  INCOME     @map("income")
  EXPENSE    @map("expense")
  ADJUSTMENT @map("adjustment")

  @@schema("finance")
}

enum ExpenseType {
  OPERATIONAL @map("operational")
  MARKETING   @map("marketing")
  PROCUREMENT @map("procurement")
  LOGISTICS   @map("logistics")
  OTHER       @map("other")

  @@schema("finance")
}

enum RecordStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@schema("users")
}

model UsersDepartment {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique @db.VarChar(64)
  name      String       @db.VarChar(255)
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles     UsersRole[]
  users     UsersUser[]

  @@map("departments")
  @@schema("users")
}

model UsersRole {
  id              String                @id @default(uuid()) @db.Uuid
  // Canonical v1 codes are seeded from docs/32: admin, seller, warehouse, logistics, finance, ceo; optional: driver, marketing.
  code            String                @unique @db.VarChar(64)
  name            String                @db.VarChar(255)
  departmentId    String?               @map("department_id") @db.Uuid
  department      UsersDepartment?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  status          RecordStatus          @default(ACTIVE)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions UsersRolePermission[]
  userRoles       UsersUserRole[]

  @@map("roles")
  @@schema("users")
}

model UsersPermission {
  id              String                @id @default(uuid()) @db.Uuid
  code            String                @unique @db.VarChar(128)
  name            String                @db.VarChar(255)
  description     String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions UsersRolePermission[]

  @@map("permissions")
  @@schema("users")
}

model UsersRolePermission {
  id           String          @id @default(uuid()) @db.Uuid
  roleId       String          @map("role_id") @db.Uuid
  role         UsersRole       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permissionId String          @map("permission_id") @db.Uuid
  permission   UsersPermission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
  @@schema("users")
}

model UsersUser {
  id                                 String                       @id @default(uuid()) @db.Uuid
  email                              String                       @unique @db.VarChar(320)
  passwordHash                       String                       @map("password_hash") @db.Text
  displayName                        String                       @map("display_name") @db.VarChar(255)
  departmentId                       String?                      @map("department_id") @db.Uuid
  department                         UsersDepartment?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  isActive                           Boolean                      @default(true) @map("is_active")
  mfaEnabled                         Boolean                      @default(false) @map("mfa_enabled")
  lastLoginAt                        DateTime?                    @map("last_login_at") @db.Timestamptz(6)
  createdAt                          DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                          DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  userRoles                          UsersUserRole[]
  crmLeadsResponsible                CrmLead[]                    @relation("CrmLeadResponsibleUser")
  crmDealsResponsible                CrmDeal[]                    @relation("CrmDealResponsibleUser")
  crmDealsDeleted                    CrmDeal[]                    @relation("CrmDealDeletedByUser")
  ordersDeleted                      OrdersOrder[]                @relation("OrdersOrderDeletedByUser")
  fulfillmentsCreated                OrdersFulfillment[]          @relation("OrdersFulfillmentCreatedByUser")
  logisticsDriverProfiles            LogisticsDriver[]            @relation("LogisticsDriverUser")
  deliveryTasksCreated               LogisticsDeliveryTask[]      @relation("LogisticsDeliveryTaskCreatedByUser")
  returnRequestsRequested            OrdersReturnRequest[]        @relation("OrdersReturnRequestRequestedByUser")
  returnRequestsCeoApproved          OrdersReturnRequest[]        @relation("OrdersReturnRequestCeoApprovedByUser")
  returnRequestsDeleted              OrdersReturnRequest[]        @relation("OrdersReturnRequestDeletedByUser")
  paymentsCreated                    PaymentsPayment[]            @relation("PaymentsPaymentCreatedByUser")
  paymentsDeleted                    PaymentsPayment[]            @relation("PaymentsPaymentDeletedByUser")
  cashOperationsCreated              PaymentsCashOperation[]      @relation("PaymentsCashOperationCreatedByUser")
  financeEntriesCreated              FinanceFinanceEntry[]        @relation("FinanceFinanceEntryCreatedByUser")
  expensesCreated                    FinanceExpense[]             @relation("FinanceExpenseCreatedByUser")
  marketingExpensesCreated           FinanceMarketingExpense[]    @relation("FinanceMarketingExpenseCreatedByUser")
  inventorySupplierRequestsRequested InventorySupplierRequest[]   @relation("InventorySupplierRequestRequestedByUser")
  inventorySupplierRequestsConfirmed InventorySupplierRequest[]   @relation("InventorySupplierRequestConfirmedByUser")
  inventorySupplierRequestsPaid      InventorySupplierRequest[]   @relation("InventorySupplierRequestPaidByUser")
  inventorySupplierRequestsStocked   InventorySupplierRequest[]   @relation("InventorySupplierRequestStockedByUser")
  inventoryPurchaseReceiptsCreated   InventoryPurchaseReceipt[]   @relation("InventoryPurchaseReceiptCreatedByUser")
  inventoryStockLocksCreated         InventoryStockLock[]         @relation("InventoryStockLockCreatedByUser")
  inventoryReservationsCreated       InventoryReservation[]       @relation("InventoryReservationCreatedByUser")
  inventoryMovementsPerformed        InventoryInventoryMovement[] @relation("InventoryInventoryMovementPerformedByUser")
  idempotencyRecordsDeleted          SystemIdempotencyRecord[]    @relation("SystemIdempotencyRecordDeletedByUser")
  outboxRecordsDeleted               SystemOutboxRecord[]         @relation("SystemOutboxRecordDeletedByUser")
  auditEventsActor                   AuditLogRecord[]             @relation("AuditLogRecordActorUser")
  auditEventsDeleted                 AuditLogRecord[]             @relation("AuditLogRecordDeletedByUser")

  @@map("users")
  @@schema("users")
}

model UsersUserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      UsersUser @relation(fields: [userId], references: [id], onDelete: Restrict)
  roleId    String    @map("role_id") @db.Uuid
  role      UsersRole @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, roleId])
  @@map("user_roles")
  @@schema("users")
}

model CrmClient {
  id                 String                 @id @default(uuid()) @db.Uuid
  clientType         String                 @map("client_type") @db.VarChar(32)
  name               String                 @db.VarChar(255)
  legalName          String?                @map("legal_name") @db.VarChar(255)
  phone              String?                @db.VarChar(64)
  email              String?                @db.VarChar(320)
  taxId              String?                @map("tax_id") @db.VarChar(64)
  notes              String?                @db.Text
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  contacts           CrmContact[]
  leads              CrmLead[]              @relation("CrmLeadClient")
  deals              CrmDeal[]              @relation("CrmDealClient")
  orders             OrdersOrder[]          @relation("OrdersOrderClient")
  clientParticipants CrmClientParticipant[] @relation("CrmClientParticipantClient")

  @@index([name])
  @@index([phone])
  @@index([email])
  @@map("clients")
  @@schema("crm")
}

model CrmContact {
  id        String    @id @default(uuid()) @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Restrict)
  name      String    @db.VarChar(255)
  phone     String?   @db.VarChar(64)
  email     String?   @db.VarChar(320)
  position  String?   @db.VarChar(255)
  isPrimary Boolean   @default(false) @map("is_primary")
  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  leads     CrmLead[] @relation("CrmLeadContact")
  deals     CrmDeal[] @relation("CrmDealContact")

  @@index([clientId])
  @@map("contacts")
  @@schema("crm")
}

model CrmLead {
  id                String      @id @default(uuid()) @db.Uuid
  source            String      @db.VarChar(128)
  status            LeadStatus
  clientId          String?     @map("client_id") @db.Uuid
  client            CrmClient?  @relation("CrmLeadClient", fields: [clientId], references: [id], onDelete: SetNull)
  contactId         String?     @map("contact_id") @db.Uuid
  contact           CrmContact? @relation("CrmLeadContact", fields: [contactId], references: [id], onDelete: SetNull)
  title             String?     @db.VarChar(255)
  notes             String?     @db.Text
  responsibleUserId String?     @map("responsible_user_id") @db.Uuid
  responsibleUser   UsersUser?  @relation("CrmLeadResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  version           Int         @default(1)
  deals             CrmDeal[]

  @@index([status])
  @@index([source])
  @@index([responsibleUserId])
  @@map("leads")
  @@schema("crm")
}

model CrmDeal {
  id                 String                 @id @default(uuid()) @db.Uuid
  leadId             String?                @map("lead_id") @db.Uuid
  lead               CrmLead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId           String                 @map("client_id") @db.Uuid
  client             CrmClient              @relation("CrmDealClient", fields: [clientId], references: [id], onDelete: Restrict)
  contactId          String?                @map("contact_id") @db.Uuid
  contact            CrmContact?            @relation("CrmDealContact", fields: [contactId], references: [id], onDelete: SetNull)
  status             DealStatus
  title              String                 @db.VarChar(255)
  deliveryMode       String?                @map("delivery_mode") @db.VarChar(32)
  notes              String?                @db.Text
  expectedValue      Decimal?               @map("expected_value") @db.Decimal(14, 2)
  responsibleUserId  String                 @map("responsible_user_id") @db.Uuid
  responsibleUser    UsersUser              @relation("CrmDealResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: Restrict)
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  version            Int                    @default(1)
  deletedAt          DateTime?              @map("deleted_at") @db.Timestamptz(6)
  deletedBy          String?                @map("deleted_by") @db.Uuid
  deletedByUser      UsersUser?             @relation("CrmDealDeletedByUser", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason       String?                @map("delete_reason") @db.Text
  isDeleted          Boolean                @default(false) @map("is_deleted")
  clientParticipants CrmClientParticipant[] @relation("CrmClientParticipantDeal")
  orders             OrdersOrder[]
  stockLocks         InventoryStockLock[]

  @@unique([leadId])
  @@index([clientId])
  @@index([status])
  @@index([responsibleUserId])
  @@index([isDeleted])
  @@map("deals")
  @@schema("crm")
}

model CrmClientParticipant {
  id        String       @id @default(uuid()) @db.Uuid
  clientId  String       @map("client_id") @db.Uuid
  client    CrmClient    @relation("CrmClientParticipantClient", fields: [clientId], references: [id], onDelete: Restrict)
  dealId    String?      @map("deal_id") @db.Uuid
  deal      CrmDeal?     @relation("CrmClientParticipantDeal", fields: [dealId], references: [id], onDelete: SetNull)
  orderId   String?      @map("order_id") @db.Uuid
  order     OrdersOrder? @relation("CrmClientParticipantOrder", fields: [orderId], references: [id], onDelete: SetNull)
  roleType  String       @map("role_type") @db.VarChar(32)
  name      String       @db.VarChar(255)
  phone     String?      @db.VarChar(64)
  notes     String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([clientId])
  @@index([dealId])
  @@index([orderId])
  @@index([roleType])
  @@map("client_participants")
  @@schema("crm")
}

model OrdersOrder {
  id                        String                       @id @default(uuid()) @db.Uuid
  orderNumber               String                       @unique @map("order_number") @db.VarChar(64)
  dealId                    String                       @map("deal_id") @db.Uuid
  deal                      CrmDeal                      @relation(fields: [dealId], references: [id], onDelete: Restrict)
  clientId                  String                       @map("client_id") @db.Uuid
  client                    CrmClient                    @relation("OrdersOrderClient", fields: [clientId], references: [id], onDelete: Restrict)
  status                    OrderStatus                  @default(ASSEMBLING)
  paymentControlStatus      OrderPaymentControlStatus    @default(NONE) @map("payment_control_status")
  paymentControlDueAt       DateTime?                    @map("payment_control_due_at") @db.Timestamptz(6)
  fulfillmentType           OrderFulfillmentType         @default(MANUAL) @map("fulfillment_type")
  deliveryStatus            OrderDeliveryStatus          @default(NOT_SCHEDULED) @map("delivery_status")
  currency                  String                       @default("RUB") @db.VarChar(3)
  subtotalAmount            Decimal                      @default(0) @map("subtotal_amount") @db.Decimal(14, 2)
  discountAmount            Decimal                      @default(0) @map("discount_amount") @db.Decimal(14, 2)
  totalAmount               Decimal                      @default(0) @map("total_amount") @db.Decimal(14, 2)
  notes                     String?                      @db.Text
  readyForPartialShipmentAt DateTime?                    @map("ready_for_partial_shipment_at") @db.Timestamptz(6)
  readyForShipmentAt        DateTime?                    @map("ready_for_shipment_at") @db.Timestamptz(6)
  partiallyShippedAt        DateTime?                    @map("partially_shipped_at") @db.Timestamptz(6)
  shippedAt                 DateTime?                    @map("shipped_at") @db.Timestamptz(6)
  createdAt                 DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version                   Int                          @default(1)
  deletedAt                 DateTime?                    @map("deleted_at") @db.Timestamptz(6)
  deletedBy                 String?                      @map("deleted_by") @db.Uuid
  deletedByUser             UsersUser?                   @relation("OrdersOrderDeletedByUser", fields: [deletedBy], references: [id], onDelete: SetNull)
  deleteReason              String?                      @map("delete_reason") @db.Text
  isDeleted                 Boolean                      @default(false) @map("is_deleted")
  items                     OrdersOrderItem[]
  fulfillments              OrdersFulfillment[]
  // TODO(phase9+): enforce delivery(1..N tasks)/pickup(0 tasks) invariant in transaction/domain layer.
  deliveryTasks             LogisticsDeliveryTask[]
  returnRequests            OrdersReturnRequest[]
  payments                  PaymentsPayment[]
  financeEntries            FinanceFinanceEntry[]
  expenses                  FinanceExpense[]             @relation("FinanceExpenseRelatedOrder")
  stockLocks                InventoryStockLock[]
  reservations              InventoryReservation[]
  inventoryMovements        InventoryInventoryMovement[]
  clientParticipants        CrmClientParticipant[]       @relation("CrmClientParticipantOrder")

  @@index([dealId])
  @@index([clientId])
  @@index([status])
  @@index([paymentControlStatus])
  @@index([fulfillmentType])
  @@index([deliveryStatus])
  @@index([isDeleted])
  @@map("orders")
  @@schema("orders")
}

model OrdersOrderItem {
  id                  String                      @id @default(uuid()) @db.Uuid
  orderId             String                      @map("order_id") @db.Uuid
  order               OrdersOrder                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  lineNo              Int                         @map("line_no")
  productId           String                      @map("product_id") @db.Uuid
  product             InventoryProduct            @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String                      @map("product_name_snapshot") @db.VarChar(255)
  qty                 Decimal                     @db.Decimal(14, 3)
  unit                ProductUnit
  retailPrice         Decimal                     @map("retail_price") @db.Decimal(14, 2)
  discountAmount      Decimal                     @default(0) @map("discount_amount") @db.Decimal(14, 2)
  lineTotal           Decimal                     @map("line_total") @db.Decimal(14, 2)
  costSnapshot        Decimal?                    @map("cost_snapshot") @db.Decimal(14, 2)
  notes               String?                     @db.Text
  createdAt           DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  version             Int                         @default(1)
  fulfillmentItems    OrdersFulfillmentItem[]
  deliveryTaskItems   LogisticsDeliveryTaskItem[]
  returnRequestItems  OrdersReturnRequestItem[]

  @@unique([orderId, lineNo])
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
  @@schema("orders")
}

model OrdersFulfillment {
  id                 String                       @id @default(uuid()) @db.Uuid
  orderId            String                       @map("order_id") @db.Uuid
  order              OrdersOrder                  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  deliveryTaskId     String?                      @map("delivery_task_id") @db.Uuid
  deliveryTask       LogisticsDeliveryTask?       @relation(fields: [deliveryTaskId], references: [id], onDelete: SetNull)
  pickupWindowId     String?                      @map("pickup_window_id") @db.Uuid
  pickupWindow       LogisticsPickupWindow?       @relation(fields: [pickupWindowId], references: [id], onDelete: SetNull)
  status             FulfillmentStatus            @default(PENDING)
  fulfillmentType    OrderFulfillmentType         @map("fulfillment_type")
  fulfilledAt        DateTime?                    @map("fulfilled_at") @db.Timestamptz(6)
  failureReason      String?                      @map("failure_reason") @db.Text
  createdBy          String                       @map("created_by") @db.Uuid
  createdByUser      UsersUser                    @relation("OrdersFulfillmentCreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt          DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version            Int                          @default(1)
  items              OrdersFulfillmentItem[]
  inventoryMovements InventoryInventoryMovement[]

  @@index([orderId])
  @@index([deliveryTaskId])
  @@index([createdBy])
  @@index([status])
  @@map("fulfillments")
  @@schema("orders")
}

model OrdersFulfillmentItem {
  id            String            @id @default(uuid()) @db.Uuid
  fulfillmentId String            @map("fulfillment_id") @db.Uuid
  fulfillment   OrdersFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Restrict)
